@startuml mcp-architecture
skinparam backgroundColor white
skinparam defaultFontSize 13
skinparam ArrowColor #555555
skinparam nodesep 60
skinparam ranksep 50

skinparam rectangle {
    BackgroundColor #F0F4FF
    BorderColor #7090C0
}

rectangle "ClientTransport\nABC — connection lifecycle" as transport
rectangle "StdioTransport\nstdio subprocess" as stdio_transport
rectangle "HttpTransport\nHTTP + subprocess" as http_transport
rectangle "BaseClient\ngeneric MCP operations" as base
rectangle "DocumentClient\ndocs:// URI scheme" as docclient
rectangle "DocumentServer\nFastMCP / stdio" as docserver
rectangle "CalendarClient\nHTTP MCP client" as toolclient
rectangle "CalendarServer\nFastMCP / HTTP :8001" as toolserver
rectangle "ChatLoop\napplication + LLM" as chat

transport <|-- stdio_transport   : implements
transport <|-- http_transport    : implements
base       o-- transport         : holds (composition)
base      <|-- docclient         : extends
base      <|-- toolclient        : extends
chat      -down-> docclient      : instantiates
chat      -down-> toolclient     : instantiates
docclient -right-> docserver     : stdio subprocess
toolclient -right-> toolserver   : HTTP localhost:8001

@enduml
